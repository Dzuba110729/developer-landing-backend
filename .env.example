APP_NAME="Developer Landing Backend"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Хранение данных — только файловое, БД не используется
DB_CONNECTION=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

# --- Почта ---
# Локально: Mailpit (https://github.com/axllent/mailpit), порт SMTP 1025, UI на 8025
# Прод: любой SMTP-провайдер (Mailtrap, Yandex, SendGrid и т.д.)
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Адрес владельца сайта — куда падают заявки с формы обратной связи
CONTACT_OWNER_EMAIL=owner@example.com

# --- AI-интеграция (Anthropic Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_TIMEOUT=10

# --- Rate limiting на /api/contact ---
CONTACT_RATE_LIMIT_MAX_ATTEMPTS=5
CONTACT_RATE_LIMIT_DECAY_MINUTES=1

# --- CORS ---
CORS_ALLOWED_ORIGINS=*
